rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['iamxeshan1@gmail.com', 'prepnexedtech@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExamPurchased(userId, examId) {
      return exists(/databases/$(database)/documents/subscriptions/$(userId + '_' + examId)) &&
             get(/databases/$(database)/documents/subscriptions/$(userId + '_' + examId)).data.paymentStatus == 'completed';
    }

    // Agencies
    match /agencies/{agencyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'address', 'district', 'state', 'profileCompleted', 'purchasedExams', 'freeExams', 'testsAttempted', 'averageScore', 'subscriptionExpiry', 'isPremium', 'premiumExpiry', 'lastReviewAt', 'emailVerified', 'updatedAt'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Exams
    match /exams/{examId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // LiveTests
    match /liveTests/{testId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledUsers'])
      );
    }
    
    // Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tests
    match /tests/{testId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Questions
    match /questions/{questionId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/tests/$(resource.data.testId)) && (
          get(/databases/$(database)/documents/tests/$(resource.data.testId)).data.isFree == true ||
          isExamPurchased(request.auth.uid, get(/databases/$(database)/documents/tests/$(resource.data.testId)).data.examId)
        )) ||
        exists(/databases/$(database)/documents/liveTests/$(resource.data.testId))
      );
      allow write: if isAdmin();
    }

    // Results
    match /results/{resultId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Premium Subscriptions
    match /premium_subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if settingId == 'general' || isAdmin();
      allow write: if isAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subjects
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin();
    }

    // Thoughts
    match /thoughts/{thoughtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Study Material
    match /study_material/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
