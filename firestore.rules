rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'iamxeshan1@gmail.com' ||
        request.auth.token.email == 'prepnexedtech@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isExamPurchased(userId, examId) {
      return exists(/databases/$(database)/documents/subscriptions/$(userId + '_' + examId)) &&
             get(/databases/$(database)/documents/subscriptions/$(userId + '_' + examId)).data.paymentStatus == 'completed';
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'purchasedExams', 'freeExams', 'testsAttempted', 'averageScore', 'subscriptionExpiry', 'isPremium', 'premiumExpiry'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Exams
    match /exams/{examId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }

    // LiveTests
    match /liveTests/{testId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledUsers'])
      );
    }
    
    // Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tests
    match /tests/{testId} {
      allow read: if true; // Allow reading test metadata
      allow write: if isAdmin();
    }

    // Questions
    match /questions/{questionId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        get(/databases/$(database)/documents/tests/$(resource.data.testId)).data.isFree == true ||
        isExamPurchased(request.auth.uid, get(/databases/$(database)/documents/tests/$(resource.data.testId)).data.examId)
      );
      allow write: if isAdmin();
    }

    // Results
    match /results/{resultId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Premium Subscriptions
    match /premium_subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if settingId == 'general' || isAdmin();
      allow write: if isAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subjects
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin();
    }

    // Thoughts
    match /thoughts/{thoughtId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
